# Copy to `.env` in the repo root and fill in the values you need.
# Only the vars relevant to the stages you run are required.

# --- Download stage ---
# parlimen.gov.my session cookie — required for PDF downloads.
# Visit parlimen.gov.my, set language to EN, then copy cookies from
# browser DevTools → Network tab → any request → Request Headers → Cookie.
# PARLIMEN_COOKIE=

# --- Analyze stage (planned) ---
# LLM provider API key. parawl uses OpenRouter by default so you can
# swap models without changing code. Get a key at openrouter.ai.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6   # or any model on OpenRouter

# --- Live integration tests (optional) ---
# Skipped by default. Run: pytest tests/test_parliament_live_year_csv_pdf.py -m live_parliament
# PARLIAMENT_LIVE_CSV_TEST=1
# PARLIAMENT_LIVE_CSV_YEAR=2024
# PARLIAMENT_LIVE_CSV_MAX_NODES=100
